# ──────────────────────────────────────────────
# Frontend environment variables
# Copy to .env and adjust as needed.
# All vars must start with VITE_ to be exposed.
# ──────────────────────────────────────────────

# Backend API URL (in dev, Vite proxies /api → this)
VITE_API_URL=http://localhost:8000

# App display name shown in the UI
VITE_APP_NAME=SQL Deployment Portal

# Auth mode: mock | oauth
VITE_AUTH_MODE=mock

# OAuth redirect URI (only for oauth mode)
# VITE_OAUTH_REDIRECT_URI=http://localhost:5173/auth/callback

# How often to poll deployment status (milliseconds)
VITE_STATUS_POLL_MS=3000

# Number of recent deployments to show in history
VITE_HISTORY_LIMIT=10
