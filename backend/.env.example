# ─────────────────────────────────────────────────────
# SQL Deployment Portal — Backend Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────

# App
APP_NAME="SQL Deployment Portal"
DEBUG=false

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ── Auth ──────────────────────────────────────────────
# Options: mock | jwt | oauth
AUTH_MODE=mock

# Secret for signing JWTs — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_MINUTES=480

# OAuth (only needed when AUTH_MODE=oauth)
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_AUTHORIZATION_URL=https://your-idp.okta.com/oauth2/v1/authorize
# OAUTH_TOKEN_URL=https://your-idp.okta.com/oauth2/v1/token
# OAUTH_USERINFO_URL=https://your-idp.okta.com/oauth2/v1/userinfo
# OAUTH_SCOPES=openid profile email groups

# Snowflake SSO (if using Snowflake as IdP)
# SNOWFLAKE_ACCOUNT_IDENTIFIER=myorg-myaccount

# ── Git ───────────────────────────────────────────────
# Options: local | remote
GIT_MODE=local
GIT_REPO_PATH=./repo

# For remote mode:
# GIT_REPO_URL=https://github.com/your-org/sql-repo.git
# GIT_BRANCH=main
GIT_SERVICE_ACCOUNT_USER=sql-portal-bot
GIT_SERVICE_ACCOUNT_EMAIL=sql-portal@company.com

# ── Airflow ───────────────────────────────────────────
# Options: mock | live
AIRFLOW_MODE=mock
AIRFLOW_BASE_URL=http://localhost:8080
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_DEFAULT_DAG_ID=sql_deploy_dag

# ── Teams config ──────────────────────────────────────
TEAMS_CONFIG_PATH=../config/teams.yaml
